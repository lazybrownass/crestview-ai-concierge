# LLM provider: "anthropic" is the production path (server-side only, never
# exposed to the browser). "ollama" is a local-dev-only swap-in — see
# docs/ollama-dev.md — and is never used in production or CI.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

MAX_TOKENS=600
MAX_INPUT_CHARS=500
RETRIEVAL_TOP_K=4

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=20

# n8n webhook that receives lead payloads (see README for the JSON contract)
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/crestview-lead

# Session cookie
SESSION_COOKIE_NAME=crestview_session
SESSION_TTL_MINUTES=60

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

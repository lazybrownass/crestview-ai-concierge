# Anthropic (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=20

# n8n webhook that receives lead payloads (see README for the JSON contract)
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/crestview-lead

# Session cookie
SESSION_COOKIE_NAME=crestview_session
SESSION_TTL_MINUTES=60

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
